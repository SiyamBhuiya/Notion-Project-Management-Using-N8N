    {
      "parameters": {
        "jsCode": "// ␀␀␀ INPUT VALIDATION ␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀␀\nconst body = $input.first().json.body ?? $input.first().json;\n\nconst REQUIRED = [\n  'project_name', 'update_type', 'content',\n  'decisions', 'status', 'next_milestone', 'owner'\n];\n\nconst missing = REQUIRED.filter(k => body[k] === undefined || body[k] === null || body[k] === '');\n\nif (missing.length > 0) {\n  return [{\n    json: {\n      valid: false,\n      error: `Missing required fields: ${missing.join(', ')}`,\n      raw: body\n    }\n  }];\n}\n\nconst VALID_UPDATE_TYPES = ['meeting_log', 'meeting log','decision', 'status_update','decision log','decision_log'];\nconst VALID_STATUSES = ['On Track', 'At Risk', 'Blocked'];\n\nif (!VALID_UPDATE_TYPES.includes(body.update_type)) {\n  return [{ json: { valid: false, error: `update_type must be one of: ${VALID_UPDATE_TYPES.join(', ')}`, raw: body } }];\n}\n\nif (!VALID_STATUSES.includes(body.status)) {\n  return [{ json: { valid: false, error: `status must be one of: ${VALID_STATUSES.join(', ')}`, raw: body } }];\n}\n\nif (!Array.isArray(body.decisions)) {\n  return [{ json: { valid: false, error: 'decisions must be an array', raw: body } }];\n}\n\nif (!Array.isArray(body.open_questions)) {\n  return [{ json: { valid: false, error: 'open_questions must be an array', raw: body } }];\n}\n\nif (!Array.isArray(body.delegations)) {\n  return [{ json: { valid: false, error: 'delegations must be an array', raw: body } }];\n}\n\n// Normalise next_milestone\nconst nm = body.next_milestone;\nconst milestone = Array.isArray(nm) ? nm[0] : nm;\nif (!milestone || !milestone.task || !milestone.date) {\n  return [{ json: { valid: false, error: 'next_milestone must contain {task, date}', raw: body } }];\n}\n\nreturn [{\n  json: {\n    valid: true,\n    project_name:    body.project_name.trim(),\n    update_type:     body.update_type,\n    content:         body.content,\n    decisions:       body.decisions,\n    status:          body.status,\n    next_milestone:  milestone,\n    owner:           body.owner,\n    blocker:         body.blocker ?? '',\n    open_questions:  body.open_questions,\n    delegations:     body.delegations,\n    timestamp: new Date().toLocaleString('en-GB', {\n  day: '2-digit',\n  month: 'short',\n  year: 'numeric',\n  hour: '2-digit',\n  minute: '2-digit',\n  hour12: false\n})\n  }\n}];\n"
      },
