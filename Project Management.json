      "parameters": {
        "jsCode": "const data = $('Validate & Normalise Input1').first().json;\nconst decisions = data.decisions;\nconst timestamp = data.timestamp;\n\nconst children = [\n  ...decisions.map(d => ({\n    object: 'block',\n    type: 'bulleted_list_item',\n    bulleted_list_item: {\n      rich_text: [{ type: 'text', text: { content: d } }]\n    }\n  })),\n  {\n    object: 'block',\n    type: 'paragraph',\n    paragraph: {\n      rich_text: [{\n        type: 'text',\n        text: { content: timestamp },\n        annotations: { color: 'gray', italic: true }\n      }]\n    }\n  },\n  {\n    object: 'block',\n    type: 'divider',\n    divider: {}\n  },\n];\n\nreturn [{\n  json: {\n    body: JSON.stringify({ children })\n  }\n}];"
      },
