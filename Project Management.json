    {
      "parameters": {
        "jsCode": "const rows = $input.first().json.results.filter(row => row.type === 'table_row');\nconst data = $('Validate & Normalise Input1').first().json;\n\nconst valueMap = {\n  'project name':   data.project_name ?? '',\n  'owner':          data.owner ?? '',\n  'status':         data.status ?? '',\n  'next milestone': data.next_milestone?.task ?? '',\n  'target date':    data.next_milestone?.date ?? '',\n  'blocker':        data.blocker ?? 'None',\n  'last updated':   data.timestamp ?? ''\n};\n\nreturn rows.map(row => {\n  const col1 = row.table_row?.cells?.[0]?.[0]?.text?.content ?? '';\n  const label = col1.toLowerCase();\n\n  // Header row\n  if (col1 === 'Field') {\n    return {\n      json: {\n        row_id: row.id,\n        body: JSON.stringify({\n          table_row: {\n            cells: [\n              [{ type: 'text', text: { content: 'Field' } }],\n              [{ type: 'text', text: { content: 'Value' } }]\n            ]\n          }\n        })\n      }\n    };\n  }\n\n  // All other rows  keep col 1, update col 2\n  const cells = [\n    [{ type: 'text', text: { content: col1 } }],\n    [{ type: 'text', text: { content: valueMap[label] ?? '' } }]\n  ];\n\n  return {\n    json: {\n      row_id: row.id,\n      body: JSON.stringify({\n        table_row: { cells }\n      })\n    }\n  };\n});"
      },
