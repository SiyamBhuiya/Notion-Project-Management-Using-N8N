    {
      "parameters": {
        "jsCode": "// Find the 'Decision Log' heading block and return its block_id\n// so we can append children INSIDE it instead of at page level.\nconst data = $input.first().json;\nconst blocks = data.results ?? [];\n\nlet decisionLogBlockId = null;\n\nfor (const block of blocks) {\n  const type = block.type;\n  // Match any heading level whose plain_text contains 'decision log' (case-insensitive)\n  const headingTypes = ['heading_1','heading_2','heading_3'];\n  if (headingTypes.includes(type)) {\n    const text = (block[type]?.rich_text ?? []).map(t => t.plain_text).join('').toLowerCase();\n    if (text.includes('decision log')) {\n      decisionLogBlockId = block.id;\n      break;\n    }\n  }\n}\n\nconst pageId = $('Project Found in Notion?').first().json.page_id;\n\n// Fall back to appending at page level if the heading doesn't exist\nreturn [{\n  json: {\n    target_block_id: decisionLogBlockId ?? pageId,\n    found_section:   decisionLogBlockId !== null\n  }\n}];\n"
      },
