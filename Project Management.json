    {
      "parameters": {
        "jsCode": "// Build a lookup map: Name (lowercase) ’ Email\nconst contactRows = $input.all();\nconst contactMap = {};\nfor (const row of contactRows) {\n  const name  = (row.json['Name'] ?? '').trim().toLowerCase();\n  const email = (row.json['Email'] ?? '').trim();\n  if (name && email) contactMap[name] = email;\n}\n\n// Get delegations from the validated input\nconst delegations = $('Validate & Normalise Input1').first().json.delegations;\nconst projectName = $('Validate & Normalise Input1').first().json.project_name;\n\nconst outputs = [];\nconst errors  = [];\n\nfor (const d of delegations) {\n  const email = contactMap[d.to.trim().toLowerCase()];\n  if (!email) {\n    errors.push(`Contact not found: ${d.to}`);\n    continue;\n  }\n  outputs.push({\n    json: {\n      to:          email,\n      name:        d.to,\n      task:        d.task,\n      due_date:    d.due_date,\n      project_name: projectName\n    }\n  });\n}\n\nif (errors.length > 0) {\n  // Add error sentinel items (will be routed to alert)\n  outputs.push({ json: { delegation_errors: errors, project_name: projectName } });\n}\n\nreturn outputs.length > 0 ? outputs : [{ json: { no_delegations: true } }];\n"
      },
