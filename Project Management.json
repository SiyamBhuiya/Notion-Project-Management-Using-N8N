    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst blocks = data.results ?? [];\n\nlet openQuestionsBlockId = null;\n\nfor (const block of blocks) {\n  const type = block.type;\n  const headingTypes = ['heading_1', 'heading_2', 'heading_3'];\n  if (headingTypes.includes(type)) {\n    const text = (block[type]?.rich_text ?? []).map(t => t.plain_text).join('').toLowerCase();\n    if (text.includes('open question')) {\n      openQuestionsBlockId = block.id;\n      break;\n    }\n  }\n}\n\nconst pageId = $('Project Found in Notion?').first().json.page_id;\n\nreturn [{\n  json: {\n    target_block_id: openQuestionsBlockId ?? pageId,\n    found_section: openQuestionsBlockId !== null\n  }\n}];"
